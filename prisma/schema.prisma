generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Participant {
  id               String   @id @default(cuid())
  name             String
  cpf              String   @unique
  email            String?  @unique
  phone            String
  passwordHash     String
  registrationCode String   @unique
  termsAcceptedAt  DateTime?
  privacyAcceptedAt DateTime?
  createdAt        DateTime @default(now())
  bets             Bet[]

  @@index([phone])
}

model Match {
  id               String    @id @default(cuid())
  matchNumber      Int       @default(0)
  stage            String    @default("group")
  groupName        String
  matchDate        String
  matchTime        String
  kickoffAt        DateTime
  homeTeam         String
  awayTeam         String
  city             String?
  country          String?
  status           String    @default("scheduled")
  officialScoreHome Int?
  officialScoreAway Int?
  resultRegisteredAt DateTime?
  resultUpdatedAt  DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  bets             Bet[]

  @@index([matchDate])
  @@index([groupName])
  @@index([stage])
}

model Bet {
  id              String      @id @default(cuid())
  participantId   String
  matchId         String
  homeScoreGuess  Int
  awayScoreGuess  Int
  submittedAt     DateTime    @default(now())
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  match           Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([participantId, matchId])
  @@index([matchId])
  @@index([participantId])
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}
